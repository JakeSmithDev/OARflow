# ─────────────────────────────────────────────────────────────────────────
# OARFlow environment. Copy to `.env` for local dev, or set these as
# environment variables in Vercel / your host. Everything has a sensible dev
# default — the app boots with NO configuration at all (PGlite + console email).
# ─────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
DEFAULT_TENANT_SLUG=pasternack

# Database — leave blank to use the zero-setup in-process Postgres (PGlite).
# In production set this to your Neon/Vercel/Supabase connection string and run
# `npm run migrate` once. Neon example:
# DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/oarflow?sslmode=require
DATABASE_URL=
# Folder PGlite persists to when DATABASE_URL is empty (or "memory://").
PGLITE_DIR=./.pglite

# Security
SESSION_COOKIE_NAME=oarflow_session
SESSION_TTL_HOURS=12
TOKEN_SECRET=change-me-to-a-long-random-string
# Encrypts tenant Stripe secrets at rest (AES-256-GCM). Set a dedicated 32+ char
# random value in production; falls back to TOKEN_SECRET if unset.
ENCRYPTION_KEY=
TOTP_ISSUER=OARFlow

# First admin user (created on seed for the default tenant)
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=changeme123

# Stripe (optional — payments/subscriptions light up when set)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Calendar (optional — set up in Admin → Settings → Integrations)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# Email (optional — falls back to a console/DB "outbox" in dev)
EMAIL_FROM=OARFlow <no-reply@oarflow.app>
EMAIL_REPLY_TO=
# Mailgun (HTTP API)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_BASE_URL=https://api.mailgun.net
# …or SMTP (used if Mailgun not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Cron protection (Vercel cron sends Authorization: Bearer $CRON_SECRET)
CRON_KEY=dev-cron-key

# File storage. Defaults to local disk (./.storage) in dev. For production set
# S3-compatible storage (AWS S3, Cloudflare R2, MinIO).
STORAGE_LOCAL_DIR=./.storage
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Twilio (optional platform-managed SMS fallback). Most tenants BYO their own
# Twilio creds in Settings → Integrations; leave blank for dev (console outbox).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Inngest (event-driven background jobs). Leave blank in dev — OARFlow runs an
# in-process fallback so reminders/SMS/webhooks/exports work keyless. In prod,
# set both and point an Inngest app at /api/inngest.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Content-Security-Policy (optional, OFF by default so a bad policy can't break a
# launch). Recommended tested value (single line) — set in your host's env to
# enable. Allows Google Fonts, Stripe.js, and the cdnjs QR library.
# CONTENT_SECURITY_POLICY=default-src 'self'; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline' https://js.stripe.com https://cdnjs.cloudflare.com; connect-src 'self' https:; frame-src https://js.stripe.com; base-uri 'self'; form-action 'self'
